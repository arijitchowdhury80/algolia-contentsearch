# === run artifacts ===
# Eval run outputs (scores + transcripts) are generated, not source. Specific
# runs cited as evidence in docs/ are force-added (git add -f); all other runs
# are ignored to keep history from churning. (Policy changed 2026-06-17.)
*.log
lab/server/output/
# Replay scorecards are generated scratch output; gold records ARE source.
lab/replay/results/
lab/capture/output/
scripts/setup/current_instructions.txt

# === editor / OS ===
.DS_Store
*.swp
.vscode/
.idea/

# === honed-prompt + calibration scratch (regenerable / local rollback) ===
scripts/setup/honed/baton_run_*.md
scripts/setup/honed/snapshot_*.txt
scripts/setup/honed/current_instructions.txt
lab/server/calibration/set.construct.json

