# Runtime env for the VPS lab backend. Copy to deploy/.env and fill the __FILL__ SECRETS.
# These mirror the SERVER-SIDE vars in the repo .env.local. NEVER commit deploy/.env.
# (deploy/.env is gitignored + dockerignored.)

# --- server ---
PORT=8787
NODE_ENV=production
LLM_PROVIDER=gemini                      # OpenAI key is dead → Gemini only

# --- auth: the shared secret Vercel sends as the x-lab-key header (= .secrets/lab_api_key.txt) ---
LAB_API_KEY=__FILL_SHARED_SECRET__

# --- LLM provider (judge + all agents run on Gemini) ---
GOOGLE_API_KEY=__FILL__

# --- Algolia CENTRAL (SERVER-SIDE ONLY — the admin key must never reach the browser) ---
ALGOLIA_APP_ID=0EXRPAXB56
ALGOLIA_ADMIN_API_KEY=__FILL__
ALGOLIA_PROVIDER_GEMINI_ID=a1ca01bf-bc28-4844-89d1-331b79c3e1ab
ALGOLIA_AGENT_MODEL=gemini-2.5-pro

# config.ts `ours` reads these (search-only browser key — used for source-preview lookups) ---
VITE_ALGOLIA_APP_ID=0EXRPAXB56
VITE_ALGOLIA_SEARCH_API_KEY=__FILL_SEARCH_ONLY_KEY__

# --- the 10 Agent Studio agent ids (not secret) ---
ALGOLIA_AGENT_P1_ID=23901423-a1de-4b6d-ac50-95bb1fbdc19e
ALGOLIA_AGENT_P3_ID=63326efb-979e-4235-97d9-ded71ff73716
ALGOLIA_AGENT_TECH_KEYWORD_ID=fb933ecc-395a-425a-9e3a-787935287bad
ALGOLIA_AGENT_TECH_NEURAL_ID=c1c425b1-0216-4d11-9c31-c7fcbe5bae01
ALGOLIA_AGENT_MARKETER_KEYWORD_ID=4d671dd3-a1d2-4dd1-b8e7-c482c02bf822
ALGOLIA_AGENT_MARKETER_NEURAL_ID=4af0897c-02e1-4107-a881-1bbacc610908
ALGOLIA_AGENT_ACADEMY_KEYWORD_ID=be89f47d-95b1-4dc3-bf80-6f715ae57b05
ALGOLIA_AGENT_ACADEMY_NEURAL_ID=74ebd5ef-4adc-487f-886e-33c9a2abf3d2
ALGOLIA_AGENT_SUPPORT_KEYWORD_ID=6851a346-42ea-4898-acff-041d30cd3ff9
